# Coinbase Advanced Trade API credentials
# Copy this to .env and fill in your real values
# chmod 600 .env after creating it

COINBASE_API_KEY=your_api_key_here
COINBASE_API_SECRET=your_api_secret_here

# Optional: Sandbox mode (set to "true" for paper trading with sandbox API)
COINBASE_SANDBOX=false

# ── Schwab / ES Futures ────────────────────────────────────────────────────
SCHWAB_APP_KEY=your_schwab_app_key
SCHWAB_APP_SECRET=your_schwab_app_secret
SCHWAB_ACCOUNT_HASH=your_account_hash

# ES execution mode
ES_DRY_RUN=true
ES_ACCOUNT_MODE=LIVE_PAPER
ES_SIM_STARTING_EQUITY=10000
ES_USE_MES=true
